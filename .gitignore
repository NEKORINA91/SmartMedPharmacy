## Visual Studio / .NET Framework .gitignore

# Build results
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/

# Visual Studio user-specific files
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# NuGet packages (restored automatically, don't commit)
packages/
*.nupkg

# Build logs
*.log

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# Test results
TestResults/

# Publish profiles / deployment
*.pubxml
*.publishproj

# Database files (if using LocalDB .mdf during dev)
*.mdf
*.ldf

# OS junk
.DS_Store
Thumbs.db

# Crash dumps
*.dmp
